APP_NAME="EasyAcct Backend"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# ── PRODUCTION (IONOS shared hosting) — copy these to .env on the server ──
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://easyacct.us

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Production: LOG_LEVEL=error

# ── Database ──
# Local: SQLite. Production on IONOS: switch to MySQL.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=db5xxxxxxxx.hosting-data.io
# DB_PORT=3306
# DB_DATABASE=dbsxxxxxxxx
# DB_USERNAME=dboxxxxxxxx
# DB_PASSWORD=

# ── Sessions / cache / queue ──
# On shared hosting (no Redis), use file drivers. Avoid the `database` driver
# in production: every cache read becomes a SQL query and burns CPU quota.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production:
# SESSION_DRIVER=file
# SESSION_ENCRYPT=true
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Production: QUEUE_CONNECTION=sync   (no worker process on shared hosting)

CACHE_STORE=database
# Production: CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ──
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="admin@easyacct.us"
MAIL_FROM_NAME="${APP_NAME}"
# Production (IONOS SMTP):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.ionos.com
# MAIL_PORT=587
# MAIL_SCHEME=tls
# MAIL_USERNAME=admin@easyacct.us
# MAIL_PASSWORD=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── CORS / admin ──
# Comma-separated list of allowed origins for the React frontend.
FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173
# Production: FRONTEND_URLS=https://easyacct.us,https://www.easyacct.us

ADMIN_NAME="EasyAcct Admin"
ADMIN_EMAIL=admin@easyacct.us
ADMIN_PASSWORD=ChangeMe123!
# Replace with a strong random token in production (e.g. `php artisan tinker` → bin2hex(random_bytes(32)))
ADMIN_API_TOKEN=easyacct-admin-local-token

VITE_APP_NAME="${APP_NAME}"
